      "parameters": {
        "jsCode": "const fileName = $json.name; // e.g., \"1234567890123_text.pdf\"\nconst fileId = $json.id;\nconst mimeType = $json.mimeType;\n\n// Extract ISBN from filename\nconst isbn = fileName.split('_')[0];\nconst fileExtension = fileName.split('.').pop().toLowerCase();\nconst isPdf = fileExtension === 'pdf';\n\nreturn [{\n  json: {\n    isbn: isbn,\n    fileName: fileName,\n    fileId: fileId,\n    mimeType: mimeType,\n    isPdf: isPdf,\n    fileExtension: fileExtension,\n    uploadTimestamp: new Date().toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        -128
      ],
      "id": "d4625cdb-f6a6-4db6-bd13-f85f405a2e47",
