      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"overall_status\": \"PASS\",\n  \"overall_confidence\": 85,\n  \"checks\": {\n    \"badge_overlap\": {\n      \"status\": \"PASS\",\n      \"confidence\": 90,\n      \"description\": \"No badge overlap detected\",\n      \"severity\": \"none\"\n    },\n    \"safe_margin\": {\n      \"status\": \"PASS\",\n      \"confidence\": 88,\n      \"description\": \"All elements within safe margins\",\n      \"severity\": \"none\"\n    },\n    \"text_border_spacing\": {\n      \"status\": \"PASS\",\n      \"confidence\": 87,\n      \"description\": \"Adequate spacing from borders\",\n      \"severity\": \"none\"\n    },\n    \"text_legibility\": {\n      \"status\": \"PASS\",\n      \"confidence\": 92,\n      \"description\": \"Text is clearly readable\",\n      \"severity\": \"none\"\n    },\n    \"image_quality\": {\n      \"status\": \"PASS\",\n      \"confidence\": 89,\n      \"description\": \"Image resolution is sufficient\",\n      \"severity\": \"none\"\n    },\n    \"text_alignment\": {\n      \"status\": \"PASS\",\n      \"confidence\": 91,\n      \"description\": \"Text is properly aligned\",\n      \"severity\": \"none\"\n    }\n  },\n  \"author_name_detected\": null,\n  \"author_name_position\": null,\n  \"title_detected\": null,\n  \"issues_summary\": [],\n  \"correction_instructions\": []\n}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        992,
        112
      ],
      "id": "59bee950-c43b-45af-a279-70a45bb7f051",
      "name": "Structured Output Parser",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prevData = $('Extract ISBN & Metadata').first().json;\n\n// Response is already a parsed object — access directly\nconst analysis = input.output || input;\n\nconst checks = analysis.checks || {};\n\n// Count issues\nconst checkEntries = Object.entries(checks);\nconst failedChecks = checkEntries.filter(([k, v]) => v.status === 'FAIL');\nconst criticalIssues = failedChecks.filter(([k, v]) => v.severity === 'critical');\nconst minorIssues = failedChecks.filter(([k, v]) => v.severity === 'minor');\n\n// Build issue markers for email\nconst issueMarkers = failedChecks.map(([key, val]) => {\n  const icon = val.severity === 'critical' ? '❌' : '⚠️';\n  return `${icon} ${key.replace(/_/g, ' ').toUpperCase()}: ${val.description}`;\n});\n\n// Build pass markers\nconst passMarkers = checkEntries\n  .filter(([k, v]) => v.status === 'PASS')\n  .map(([key, val]) => `✅ ${key.replace(/_/g, ' ').toUpperCase()}: ${val.description}`);\n\nreturn [{\n  json: {\n    isbn: prevData.isbn,\n    fileName: prevData.fileName,\n    uploadTimestamp: prevData.uploadTimestamp,\n    overall_status: analysis.overall_status || 'REVIEW_NEEDED',\n    overall_confidence: analysis.overall_confidence || 0,\n    author_name: analysis.author_name_detected || 'Unknown',\n    author_position: analysis.author_name_position || 'Unknown',\n    book_title: analysis.title_detected || 'Unknown',\n    total_issues: failedChecks.length,\n    critical_issues: criticalIssues.length,\n    minor_issues: minorIssues.length,\n    badge_overlap_status: checks.badge_overlap?.status || 'UNKNOWN',\n    badge_overlap_confidence: checks.badge_overlap?.confidence || 0,\n    safe_margin_status: checks.safe_margin?.status || 'UNKNOWN',\n    text_legibility_status: checks.text_legibility?.status || 'UNKNOWN',\n    image_quality_status: checks.image_quality?.status || 'UNKNOWN',\n    text_alignment_status: checks.text_alignment?.status || 'UNKNOWN',\n    issues_summary: (analysis.issues_summary || []).join(', '),\n    correction_instructions: (analysis.correction_instructions || []).join('\\n'),\n    issue_markers: issueMarkers.join('\\n'),\n    pass_markers: passMarkers.join('\\n'),\n    all_checks_detail: JSON.stringify(checks)\n  }\n}];"
      },
